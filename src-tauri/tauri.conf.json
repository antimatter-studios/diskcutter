{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Disk Cutter",
  "version": "2026.5.18",
  "identifier": "com.diskcutter.app",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Disk Cutter",
        "width": 1480,
        "height": 940,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Chris Thomas",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: Chris Thomas (43UMKXZ8P4)",
      "entitlements": "macos/entitlements.plist"
    }
  }
}
